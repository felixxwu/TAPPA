; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="TAPPA"
config/version="0.0-dev"
run/main_scene="res://hq.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

; Web exports are single-threaded (thread_support=false): audio is mixed on the
; MAIN thread, interleaved with the game loop, instead of on a dedicated audio
; thread like desktop. With the aggressive 30 fps thermal cap on mobile/web
; (target_fps_mobile, see world.gd / game_config.gd) the main thread sleeps
; ~33 ms between frames, so the default 15 ms output buffer drains and underruns
; -> audible crackle/breakup. A larger latency gives the buffer enough slack to
; survive the gap between frame-driven refills. Only the .web override changes;
; desktop keeps Godot's tight default.
driver/output_latency=15
driver/output_latency.web=120

[autoload]

Config="*res://scripts/config.gd"
Save="*res://scripts/save_manager.gd"
InputRemap="*res://scripts/input_remap.gd"
RallySession="*res://scripts/rally_session.gd"
Benchmark="*res://scripts/benchmark_mode.gd"
DisplayStretch="*res://scripts/display_stretch.gd"
PerfLog="*res://scripts/perf_log.gd"

[display]

window/size/viewport_width=100
window/size/viewport_height=400
window/size/window_width_override=1280
window/size/window_height_override=960
window/stretch/mode="viewport"
window/stretch/aspect="keep_height"
window/handheld/orientation="sensor_landscape"

[filesystem]

import/blender/enabled=false

[gui]

theme/custom="res://theme/ui_theme.tres"

[importer_defaults]

texture={
"compress/lossy_quality": 0.7,
"compress/mode": 1
}

