# Godot 4 editor cache
/.godot/

# Build / export artifacts
/build/

# Model-iteration render output (regenerated by tools/render_model.gd)
/tools/render_out/

# Low-poly tree verification renders (regenerated by tools/lowpoly_tree.gd)
/tools/tree_renders/

# Leaf texture Godot extracts from the embedded low_poly_tree.glb on import
# (a copy of textures/leaves.png; regenerated automatically on reimport)
/models/low_poly_tree_leaves.png
/models/low_poly_tree_leaves.png.import

# Sign-arrow preview contact sheet (regenerated by tools/bake_sign_arrows.gd)
sign_arrows_contact.png

# In-context sign screenshot (regenerated by tools/sign_capture.tscn)
sign_trackside_check.png

# Controlled single-sign orientation render (tools/controlled_sign.tscn)
sign_controlled.png

# UI design-system proof renders (regenerated by tools/ui_preview.tscn /
# tools/pause_capture.tscn)
/tools/ui_preview.png
/tools/ui_preview.png.import
/tools/pause_capture.png
/tools/pause_capture.png.import
/tools/menu_*.png
/tools/menu_*.png.import

# Font-comparison scratch (tools/font_compare.tscn) — candidate fonts being
# evaluated + the comparison render. Kept out of the repo until a font is chosen.
/fonts/candidates/
/tools/font_compare.gd
/tools/font_compare.gd.uid
/tools/font_compare.tscn
/tools/font_compare.png
/tools/font_compare.png.import

# Local secrets / env
.env

# Superpowers brainstorm/session scratch artifacts
/.superpowers/

/docs/superpowers/